    {
      "id": "RENJIAO-G1-MATH-S-ku-10加几和相应的减法",
      "textbook_id": "RENJIAO-G1-MATH-S",
      "cluster_id": "RENJIAO-G1-MATH-S-kc-11-20各数的认识与组成",
      "name": "10加几和相应的减法",
      "description": "10+3=13，13-3=10，13-10=3。",
      "prerequisites": [
        "11～20的组成"
      ],
      "related_kus": [],
      "difficulty": 0.3,
      "exam_frequency": "mid",
      "question_types": [
        "short_answer"
      ],
      "ku_type": "concept",
      "curriculum_standard": null,
      "mastery_levels": [],
      "rich_content": {
        "examples": [
          "$10 + 7 = 17, 17 - 7 = 10, 17 - 10 = 7$。这里展示了加法和减法的相互关系。",
          "$10 + 4 = 14, 14 - 4 = 10, 14 - 10 = 4$。进一步说明了基本运算规律"
        ],
        "intuition": "理解10加几和相应的减法有助于学生建立数感，掌握基本运算规律，为后续学习打下基础。",
        "definition": "在十进制系统中，$10 + n = 10 + n$（其中$n \\in [0,9]$），而$10 + n - n = 10$。",
        "key_points": [
          "⚠️ 最易误解的点1：混淆加法和减法的操作顺序",
          "⚠️ 最易误解的点2：误认为$13-3=10$，忽略借位规则"
        ],
        "application": [
          "典型考查方式之一是通过填空题或选择题检验学生对基本运算规则的理解",
          "另一种常见形式是在实际问题中应用这些概念，如购物找零等情境"
        ],
        "connections": "此知识点与后续的进位制运算、多位数加减法密切相关。",
        "common_mistakes": [
          "学生常犯的具体错误1：在进行加法和减法时混淆操作顺序，比如先做减法再做加法",
          "具体错误2：在处理借位问题时出现错误，如$13-4=9$而非正确的$9$"
        ],
        "counter_examples": "如将$13-3=12$误认为正确，忽略了减法中被减数必须大于或等于减数的基本规则。"
      },
      "provenance": null,
      "source_excerpt": null,
      "ai_generated": true,
      "verified": false
    },
