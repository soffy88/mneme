{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oprim/performance/cagr.schema.json",
  "title": "cagr Input",
  "description": "Compute Compound Annual Growth Rate (CAGR). Reference: Bodie, Kane, Marcus (2014).",
  "type": "object",
  "required": ["returns"],
  "properties": {
    "returns": {
      "description": "Period return series",
      "type": "array",
      "items": {"type": "number"},
      "minItems": 1
    },
    "periods_per_year": {
      "description": "Number of periods per year (e.g., 252 for daily, 12 for monthly).",
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 252
    },
    "method": {
      "description": "Annualization method: 'geometric' or 'arithmetic'.",
      "type": "string",
      "enum": ["geometric", "arithmetic"],
      "default": "geometric"
    }
  }
}
