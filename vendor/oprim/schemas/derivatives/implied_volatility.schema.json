{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oprim/derivatives/implied_volatility.schema.json",
  "title": "implied_volatility Input",
  "description": "Implied volatility from market price. Reference: Manaster & Koehler (1982).",
  "type": "object",
  "required": ["market_price", "spot", "strike", "time_to_expiry", "risk_free_rate"],
  "properties": {
    "market_price": {
      "description": "Observed market price of the option",
      "type": "number",
      "minimum": 0
    },
    "spot": {
      "description": "Current asset price",
      "type": "number",
      "minimum": 0
    },
    "strike": {
      "description": "Strike price",
      "type": "number",
      "minimum": 0
    },
    "time_to_expiry": {
      "description": "Time to expiry in years",
      "type": "number",
      "minimum": 0
    },
    "risk_free_rate": {
      "description": "Continuously compounded risk-free rate",
      "type": "number"
    },
    "option_type": {
      "description": "Option type: 'call' or 'put'",
      "type": "string",
      "enum": ["call", "put"],
      "default": "call"
    },
    "dividend_yield": {
      "description": "Continuous dividend yield",
      "type": "number",
      "default": 0.0
    },
    "method": {
      "description": "Root-finding method: 'brent' or 'newton'",
      "type": "string",
      "enum": ["brent", "newton"],
      "default": "brent"
    },
    "tolerance": {
      "description": "Convergence tolerance",
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 1e-6
    },
    "max_iter": {
      "description": "Maximum iterations",
      "type": "integer",
      "minimum": 1,
      "default": 100
    }
  }
}
