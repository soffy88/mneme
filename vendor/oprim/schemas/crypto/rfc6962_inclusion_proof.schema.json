{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oprim/crypto/rfc6962_inclusion_proof.schema.json",
  "title": "RFC 6962 Inclusion Proof Input",
  "type": "object",
  "required": ["leaves", "leaf_index"],
  "properties": {
    "leaves": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "leaf_index": {"type": "integer", "minimum": 0}
  }
}
