{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oprim/crypto/rfc6962_merkle_root.schema.json",
  "title": "RFC 6962 Merkle Root Input",
  "type": "object",
  "required": ["leaves"],
  "properties": {
    "leaves": {
      "description": "List of leaf data (arbitrary bytes, hex-encoded for JSON)",
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
