{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oprim/technical/vwap.schema.json",
  "title": "VWAP Input",
  "type": "object",
  "required": ["prices", "volumes"],
  "properties": {
    "prices": {
      "type": "array",
      "items": {"type": "number"},
      "minItems": 1
    },
    "volumes": {
      "type": "array",
      "items": {"type": "number", "minimum": 0},
      "minItems": 1
    },
    "window": {
      "oneOf": [
        {"type": "integer", "minimum": 1},
        {"type": "null"}
      ]
    }
  }
}
