{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://3o-spec.org/schemas/oprim/technical/rsi_normalized.schema.json",
  "title": "RSI Normalized Input",
  "type": "object",
  "required": ["prices"],
  "properties": {
    "prices": {
      "type": "array",
      "items": {"type": "number"},
      "minItems": 1
    },
    "period": {"type": "integer", "minimum": 1, "default": 14}
  }
}
