{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omodul.local/schemas/strategies/funding_rate_arbitrage",
  "title": "Funding Rate Arbitrage Config",
  "description": "Configuration schema for funding_rate_arbitrage strategy.",
  "type": "object",
  "required": [
    "funding_threshold_bps_long", "funding_threshold_bps_short",
    "basis_filter_bps", "lookback_hours",
    "target_annual_vol", "max_position_pct", "rebalance_threshold",
    "daily_loss_halt_pct", "weekly_loss_halt_pct",
    "volatility_halt_multiplier", "baseline_realized_vol",
    "daily_volume_usd", "realized_vol_30d"
  ],
  "properties": {
    "max_leverage": {
      "type": "number",
      "minimum": 1.0,
      "maximum": 3.0,
      "default": 2.0,
      "description": "Maximum gross leverage."
    },
    "funding_threshold_bps_long": {
      "type": "number",
      "exclusiveMinimum": 0.0,
      "description": "Long threshold in bps."
    },
    "funding_threshold_bps_short": {
      "type": "number",
      "exclusiveMinimum": 0.0,
      "description": "Short threshold in bps."
    },
    "basis_filter_bps": {
      "type": "number",
      "minimum": 0.0,
      "description": "Residual anomaly filter in bps."
    },
    "lookback_hours": {
      "type": "integer",
      "minimum": 8,
      "description": "Funding rate lookback in hours."
    },
    "target_annual_vol": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "max_position_pct": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "rebalance_threshold": {
      "type": "number",
      "minimum": 0.0
    },
    "daily_loss_halt_pct": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "weekly_loss_halt_pct": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "volatility_halt_multiplier": {
      "type": "number",
      "minimum": 1.0
    },
    "baseline_realized_vol": {
      "type": "number",
      "exclusiveMinimum": 0.0
    },
    "daily_volume_usd": {
      "type": "number",
      "exclusiveMinimum": 0.0
    },
    "realized_vol_30d": {
      "type": "number",
      "minimum": 0.0
    },
    "n_twap_slices": {
      "type": "integer",
      "minimum": 1,
      "default": 5
    },
    "slice_duration_sec": {
      "type": "integer",
      "minimum": 1,
      "default": 60
    }
  },
  "additionalProperties": false
}
