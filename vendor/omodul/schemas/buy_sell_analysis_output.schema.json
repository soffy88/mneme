{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "buy_sell_analysis_output.schema.json",
  "title": "BuySellAnalysisOutput",
  "type": "object",
  "required": ["symbol", "analysis", "cache_status", "cost", "trail_id"],
  "properties": {
    "symbol": {"type": "string"},
    "analysis": {
      "type": "object",
      "required": ["action_suggestion", "entry_price_range", "exit_price_range", "rationale", "key_risks", "confidence"],
      "properties": {
        "action_suggestion": {"type": "string", "enum": ["buy_now", "wait", "sell", "hold"]},
        "entry_price_range": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
        "exit_price_range": {"type": "array", "items": {"type": "number"}, "minItems": 2, "maxItems": 2},
        "rationale": {"type": "string"},
        "key_risks": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0}
      }
    },
    "cache_status": {"type": "string"},
    "cost": {"type": "number"},
    "trail_id": {"type": "string"}
  }
}
